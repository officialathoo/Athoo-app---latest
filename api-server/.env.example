NODE_ENV=development
PORT=5000
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require
JWT_SECRET=change-me
SESSION_SECRET=change-me
CORS_ORIGIN=http://localhost:5173,http://localhost:8081
API_BASE_URL=http://localhost:5000
ADMIN_BASE_URL=http://localhost:5173
APP_BASE_URL=http://localhost:8081


GOOGLE_MAPS_API_KEY=
FCM_SERVER_KEY=
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=Athoo <no-reply@athoo.pk>

# Production safety defaults
BODY_LIMIT=2mb
GLOBAL_RATE_LIMIT_WINDOW_MS=60000
GLOBAL_RATE_LIMIT_MAX=600
SERVER_REQUEST_TIMEOUT_MS=30000
SERVER_HEADERS_TIMEOUT_MS=35000
SERVER_KEEP_ALIVE_TIMEOUT_MS=5000
DB_POOL_MAX=20
MAX_UPLOAD_BYTES=52428800
ALLOWED_UPLOAD_MIME_TYPES=image/jpeg,image/png,image/webp,application/pdf,video/mp4,video/quicktime
PUSH_PROVIDER=expo
PUSH_TIMEOUT_MS=10000
EXPO_PUSH_BATCH_SIZE=100

# Cost/speed policy: static location + distance only. Set true only if you later re-enable live moving tracking.
ENABLE_LIVE_TRACKING=false

# Native call / WebRTC production settings
EXPO_PUBLIC_TURN_URLS=turn:turn.your-domain.com:3478,turns:turn.your-domain.com:5349
EXPO_PUBLIC_TURN_USERNAME=
EXPO_PUBLIC_TURN_CREDENTIAL=
TURN_URLS=turn:turn.your-domain.com:3478,turns:turn.your-domain.com:5349
TURN_USERNAME=
TURN_CREDENTIAL=

# Queues / cache / high traffic
QUEUE_PROVIDER=postgres
CACHE_PROVIDER=memory
MICRO_CACHE_TTL_MS=1000
GLOBAL_RATE_LIMIT_MAX=1200

# Monitoring
LOG_LEVEL=info
SENTRY_DSN=
OTEL_EXPORTER_OTLP_ENDPOINT=

# Cloudflare R2 / S3-compatible storage (production)
STORAGE_PROVIDER=r2
CLOUDFLARE_R2_ACCOUNT_ID=
CLOUDFLARE_R2_ACCESS_KEY_ID=
CLOUDFLARE_R2_SECRET_ACCESS_KEY=
CLOUDFLARE_R2_BUCKET=athoo
S3_ENDPOINT=https://YOUR_ACCOUNT_ID.r2.cloudflarestorage.com
S3_REGION=auto
S3_FORCE_PATH_STYLE=true
STORAGE_UPLOAD_PREFIX=uploads
SIGNED_UPLOAD_TTL_SECONDS=900
SIGNED_READ_TTL_SECONDS=900
ALLOWED_UPLOAD_MIME_TYPES=image/jpeg,image/png,image/webp,application/pdf,video/mp4,video/quicktime,video/x-m4v
MAX_UPLOAD_BYTES=209715200

# Development seed safety
SEED_ADMIN_PASSWORD=
SEED_DEMO_PASSWORD=
