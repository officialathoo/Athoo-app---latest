# Root/workspace reference. Copy required values into each deployed service.
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require
JWT_SECRET=change-this-long-random-secret
SESSION_SECRET=change-this-long-random-secret
CORS_ORIGIN=https://your-admin-domain.onrender.com,https://your-mobile-web-domain.com
VITE_API_BASE_URL=https://your-backend.onrender.com
EXPO_PUBLIC_API_BASE_URL=https://your-backend.onrender.com
EXPO_ACCESS_TOKEN=
GOOGLE_MAPS_API_KEY=

# Native call / WebRTC production settings
EXPO_PUBLIC_TURN_URLS=turn:turn.your-domain.com:3478,turns:turn.your-domain.com:5349
EXPO_PUBLIC_TURN_USERNAME=
EXPO_PUBLIC_TURN_CREDENTIAL=
TURN_URLS=turn:turn.your-domain.com:3478,turns:turn.your-domain.com:5349
TURN_USERNAME=
TURN_CREDENTIAL=

# Queues / cache / high traffic
REDIS_URL=redis://localhost:6379
QUEUE_PROVIDER=postgres
CACHE_PROVIDER=memory
MICRO_CACHE_TTL_MS=1000
GLOBAL_RATE_LIMIT_MAX=1200

# Monitoring
LOG_LEVEL=info
SENTRY_DSN=
OTEL_EXPORTER_OTLP_ENDPOINT=

# v14 production hardening
REDIS_URL=
QUEUE_PROVIDER=postgres
CALL_PROVIDER=webrtc
STUN_URL=stun:stun.l.google.com:19302
TURN_URL=
TURN_USERNAME=
TURN_CREDENTIAL=
SENTRY_DSN=
ERROR_TRACKING_DSN=
MAX_CALL_AUDIO_CHUNK_B64=900000
CALL_FALLBACK_CHUNK_MS=800

# Cloudflare R2 / S3-compatible storage
CLOUDFLARE_R2_ACCOUNT_ID=
CLOUDFLARE_R2_ACCESS_KEY_ID=
CLOUDFLARE_R2_SECRET_ACCESS_KEY=
CLOUDFLARE_R2_BUCKET=athoo
S3_ENDPOINT=https://YOUR_ACCOUNT_ID.r2.cloudflarestorage.com
S3_REGION=auto
S3_FORCE_PATH_STYLE=true
STORAGE_UPLOAD_PREFIX=uploads
SIGNED_UPLOAD_TTL_SECONDS=900
SIGNED_READ_TTL_SECONDS=900
ALLOWED_UPLOAD_MIME_TYPES=image/jpeg,image/png,image/webp,application/pdf,video/mp4,video/quicktime,video/x-m4v
MAX_UPLOAD_BYTES=209715200

# Security hardening
UPLOAD_URL_RATE_LIMIT_MAX=120
MAX_UPLOAD_BYTES=209715200
ALLOWED_UPLOAD_MIME_TYPES=image/jpeg,image/png,image/webp,application/pdf,video/mp4,video/quicktime,video/mov,video/x-m4v

# Development seed safety
SEED_ADMIN_PASSWORD=
SEED_DEMO_PASSWORD=

# Operations and incident readiness
BACKUP_RETENTION_DAYS=30
AUDIT_LOG_RETENTION_DAYS=365
FAILED_JOB_RETENTION_DAYS=30
INCIDENT_COMMANDER_CONTACT=
SUPPORT_ESCALATION_EMAIL=
STATUS_PAGE_URL=
