# Athoo development environment (portable)
NODE_ENV=development
PORT=5000
DOMAIN_NAME=localhost
API_BASE_URL=http://localhost:5000
ADMIN_BASE_URL=http://localhost:5173
APP_BASE_URL=http://localhost:8081
MOBILE_APP_SCHEME=athoo
DATABASE_URL=postgresql://athoo:athoo_password@localhost:5432/athoo
REDIS_URL=redis://localhost:6379
JWT_SECRET=replace-with-long-random-secret
REFRESH_TOKEN_SECRET=replace-with-long-random-refresh-secret
SESSION_SECRET=replace-with-long-random-session-secret
CORS_ORIGIN=http://localhost:5173,http://localhost:8081
CORS_ORIGINS=http://localhost:5173,http://localhost:8081
STORAGE_PROVIDER=local
STORAGE_BUCKET=athoo-dev
STORAGE_ENDPOINT=http://localhost:5000
STORAGE_ACCESS_KEY=
STORAGE_SECRET_KEY=
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
PUSH_PROVIDER=expo
MAPS_PROVIDER=google
GOOGLE_MAPS_API_KEY=
EMAIL_PROVIDER=smtp
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
RATE_LIMIT_CONFIG=development
BODY_LIMIT=2mb
SERVER_REQUEST_TIMEOUT_MS=60000
SERVER_HEADERS_TIMEOUT_MS=65000
SERVER_KEEP_ALIVE_TIMEOUT_MS=5000

# Native call / WebRTC production settings
EXPO_PUBLIC_TURN_URLS=turn:turn.your-domain.com:3478,turns:turn.your-domain.com:5349
EXPO_PUBLIC_TURN_USERNAME=
EXPO_PUBLIC_TURN_CREDENTIAL=
TURN_URLS=turn:turn.your-domain.com:3478,turns:turn.your-domain.com:5349
TURN_USERNAME=
TURN_CREDENTIAL=

# Queues / cache / high traffic
REDIS_URL=redis://localhost:6379
QUEUE_PROVIDER=memory
CACHE_PROVIDER=memory
MICRO_CACHE_TTL_MS=1000
GLOBAL_RATE_LIMIT_MAX=1200

# Monitoring
LOG_LEVEL=info
SENTRY_DSN=
OTEL_EXPORTER_OTLP_ENDPOINT=
