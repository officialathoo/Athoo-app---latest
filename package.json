{
  "name": "workspace",
  "version": "0.0.0",
  "license": "MIT",
  "scripts": {
    "preinstall": "node ./scripts/tools/verify-package-manager.mjs",
    "build": "pnpm -r --filter \"./lib/**\" --if-present run build && pnpm --filter \"./api-server\" run build && pnpm --filter \"./admin-panel\" run build",
    "typecheck:libs": "tsc --build",
    "typecheck": "pnpm run typecheck:libs && pnpm -r --filter \"./api-server\" --filter \"./admin-panel\" --filter \"./athoo-app\" --filter \"./scripts\" --if-present run typecheck",
    "start:api": "pnpm --filter @workspace/api-server start",
    "dev:api": "pnpm --filter @workspace/api-server dev",
    "dev:admin": "pnpm --filter @workspace/admin-panel dev",
    "check:project": "node ./scripts/tools/project-check.mjs",
    "clean": "node ./scripts/tools/clean.mjs",
    "verify": "pnpm run check:project && pnpm run test && pnpm run typecheck && pnpm run build",
    "start:mobile": "pnpm --filter @workspace/athoo-app start",
    "typecheck:mobile": "pnpm --filter @workspace/athoo-app typecheck",
    "test": "pnpm -r --if-present run test",
    "db:migrate": "pnpm --filter @workspace/scripts db:migrate",
    "db:status": "pnpm --filter @workspace/scripts db:status",
    "db:verify": "pnpm --filter @workspace/scripts db:verify",
    "db:backup": "node ./scripts/tools/db-backup.mjs",
    "db:restore": "node ./scripts/tools/db-restore.mjs",
    "release:check": "node ./scripts/tools/release-check.mjs",
    "release:verify": "pnpm run check:project && pnpm run release:check && pnpm run test && pnpm run typecheck && pnpm run build && pnpm run db:verify",
    "mobile:doctor": "pnpm --filter @workspace/athoo-app run doctor",
    "release:verify:code": "pnpm run check:project && pnpm run release:check && pnpm run ops:validate && pnpm run release:blueprints:validate && pnpm run security:scan && pnpm run mobile:workspace:validate && pnpm run mobile:styles:validate && pnpm run test && pnpm run typecheck && pnpm run mobile:metro:validate && pnpm run build",
    "admin:bootstrap": "pnpm --filter @workspace/scripts bootstrap:admin",
    "env:validate": "node ./scripts/tools/validate-environment.mjs",
    "smoke:test": "node ./scripts/tools/smoke-test.mjs",
    "staging:verify": "pnpm run release:verify:code && pnpm run env:validate",
    "mobile:validate": "node ./scripts/tools/validate-mobile-release.mjs",
    "mobile:export": "pnpm --filter @workspace/athoo-app run export",
    "mobile:verify": "pnpm run mobile:validate && pnpm run typecheck:mobile && pnpm run mobile:export",
    "beta:validate": "node ./scripts/tools/validate-beta-qa.mjs",
    "beta:api-smoke": "node ./scripts/tools/beta-api-smoke.mjs",
    "beta:verify": "pnpm run release:verify:code && pnpm run mobile:validate && pnpm run beta:validate",
    "ops:validate": "node ./scripts/tools/validate-operations-readiness.mjs",
    "release:evidence": "node ./scripts/tools/generate-release-evidence.mjs",
    "launch:preflight": "node ./scripts/tools/launch-preflight.mjs",
    "launch:postdeploy": "node ./scripts/tools/postdeploy-verify.mjs",
    "rc:workflow-smoke": "node ./scripts/tools/rc-workflow-smoke.mjs",
    "db:integrity": "pnpm --filter @workspace/scripts db:integrity",
    "db:rehearse": "node ./scripts/tools/db-rehearse.mjs",
    "db:tools-check": "node ./scripts/tools/db-tools-check.mjs",
    "security:scan": "node ./scripts/tools/security-scan.mjs",
    "performance:smoke": "node ./scripts/tools/performance-smoke.mjs",
    "device:validate": "node ./scripts/tools/validate-device-acceptance.mjs",
    "device:prepare": "pnpm run mobile:validate && pnpm run beta:validate && pnpm run device:validate && pnpm run typecheck:mobile",
    "rc1:decision": "node ./scripts/tools/rc1-decision.mjs",
    "runtime:verify:connected": "node ./scripts/tools/connected-runtime-verify.mjs",
    "release:verify:connected": "pnpm run release:verify:code && pnpm run db:verify && pnpm run runtime:verify:connected",
    "device:evidence:init": "node ./scripts/tools/init-device-evidence.mjs",
    "device:evidence:validate": "node ./scripts/tools/validate-device-evidence.mjs",
    "rc2:source-verify": "pnpm run release:verify:code && pnpm run mobile:validate && pnpm run beta:validate && pnpm run device:validate",
    "rc2:connected-verify": "pnpm run release:verify:connected",
    "rc2:decision": "node ./scripts/tools/rc2-decision.mjs",
    "mobile:align-sdk": "node ./scripts/tools/align-expo-sdk.mjs",
    "mobile:styles:validate": "node ./scripts/tools/validate-react-native-styles.mjs",
    "mobile:repair-toolchain": "node ./scripts/tools/repair-expo-toolchain.mjs",
    "mobile:workspace:validate": "node ./scripts/tools/validate-expo-workspace.mjs",
    "mobile:metro:validate": "node ./scripts/tools/validate-metro-config.mjs",
    "release:blueprints:validate": "node ./scripts/tools/validate-release-blueprints.mjs",
    "storage:migrate": "node ./api-server/scripts/storage-migrate.mjs",
    "storage:verify": "node ./api-server/scripts/storage-migrate.mjs --verify-only"
  },
  "private": true,
  "devDependencies": {
    "prettier": "^3.8.1",
    "typescript": "~5.9.2"
  },
  "packageManager": "pnpm@10.33.2",
  "engines": {
    "node": ">=22 <23",
    "pnpm": ">=10.33.2 <11"
  },
  "optionalDependencies": {
    "@rollup/rollup-win32-x64-msvc": "4.62.2"
  }
}
