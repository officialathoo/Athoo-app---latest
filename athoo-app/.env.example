# Mobile app config. Use your own domain; do not hardcode Render/Replit/Neon URLs.
EXPO_PUBLIC_API_BASE_URL=https://api.athoo.pk
EXPO_PUBLIC_GOOGLE_MAPS_API_KEY=
EXPO_PUBLIC_PROJECT_ID=

# Native call / WebRTC production settings

# Queues / cache / high traffic
REDIS_URL=redis://localhost:6379
QUEUE_PROVIDER=memory
CACHE_PROVIDER=memory
MICRO_CACHE_TTL_MS=1000
GLOBAL_RATE_LIMIT_MAX=1200

# Monitoring
LOG_LEVEL=info
SENTRY_DSN=
OTEL_EXPORTER_OTLP_ENDPOINT=

# TURN credentials are returned by the authenticated API /api/calls/config.
# Never embed TURN usernames or credentials in EXPO_PUBLIC_* variables.
