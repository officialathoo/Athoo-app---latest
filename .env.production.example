# Athoo production environment (own domain / VPS / any cloud)
NODE_ENV=production
PORT=10000
DOMAIN_NAME=athoo.pk
API_BASE_URL=https://api.athoo.pk
ADMIN_BASE_URL=https://admin.athoo.pk
APP_BASE_URL=https://app.athoo.pk
MOBILE_APP_SCHEME=athoo
DATABASE_URL=postgresql://neondb_owner:npg_rP8jcUu6ChKi@ep-wild-wind-ahpjribw-pooler.c-3.us-east-1.aws.neon.tech/neondb?sslmode=require&channel_binding=require
DATABASE_DIRECT_URL=postgresql://neondb_owner:npg_rP8jcUu6ChKi@ep-wild-wind-ahpjribw.c-3.us-east-1.aws.neon.tech/neondb?sslmode=require&channel_binding=require
REDIS_URL=redis://redis:6379
JWT_SECRET=CHANGE_ME_LONG_RANDOM_64_CHARS_MIN
REFRESH_TOKEN_SECRET=CHANGE_ME_LONG_RANDOM_64_CHARS_MIN
SESSION_SECRET=CHANGE_ME_LONG_RANDOM_64_CHARS_MIN
CORS_ORIGIN=https://admin.athoo.pk,https://app.athoo.pk
CORS_ORIGINS=https://admin.athoo.pk,https://app.athoo.pk
STORAGE_PROVIDER=r2
PUSH_PROVIDER=expo
MAPS_PROVIDER=google
GOOGLE_MAPS_API_KEY=CHANGE_ME
EMAIL_PROVIDER=smtp
SMTP_HOST=smtp.your-provider.com
SMTP_PORT=587
SMTP_USER=CHANGE_ME
SMTP_PASS=CHANGE_ME
RATE_LIMIT_CONFIG=production
GLOBAL_RATE_LIMIT_WINDOW_MS=60000
GLOBAL_RATE_LIMIT_MAX=600
BODY_LIMIT=2mb
MAX_STRING_FIELD_LENGTH=1200000
SERVER_REQUEST_TIMEOUT_MS=60000
SERVER_HEADERS_TIMEOUT_MS=65000
SERVER_KEEP_ALIVE_TIMEOUT_MS=5000

# Native call / WebRTC production settings
EXPO_PUBLIC_TURN_URLS=turn:turn.your-domain.com:3478,turns:turn.your-domain.com:5349
EXPO_PUBLIC_TURN_USERNAME=
EXPO_PUBLIC_TURN_CREDENTIAL=
TURN_URLS=turn:turn.your-domain.com:3478,turns:turn.your-domain.com:5349
TURN_USERNAME=
TURN_CREDENTIAL=

# Queues / cache / high traffic
QUEUE_PROVIDER=postgres
CACHE_PROVIDER=memory
MICRO_CACHE_TTL_MS=1000

# Monitoring
LOG_LEVEL=info
SENTRY_DSN=
OTEL_EXPORTER_OTLP_ENDPOINT=

# v14 production hardening
CALL_PROVIDER=webrtc
STUN_URL=stun:stun.l.google.com:19302
TURN_URL=
ERROR_TRACKING_DSN=
MAX_CALL_AUDIO_CHUNK_B64=900000
CALL_FALLBACK_CHUNK_MS=800

# Cloudflare R2 / S3-compatible storage
CLOUDFLARE_R2_ACCOUNT_ID=f788221dead864592cf1cefb82d22911
CLOUDFLARE_R2_ACCESS_KEY_ID=f173e31a70964a15a91950266ff085a2d
CLOUDFLARE_R2_SECRET_ACCESS_KEY=5a4b91bd5f09c5dc76f6e8053ca021add7f0a14f262d226eeccf766c6b31e1d1
CLOUDFLARE_R2_BUCKET=athoo
S3_ENDPOINT=https://f788221dead864592cf1cefb82d22911.r2.cloudflarestorage.com
S3_REGION=auto
S3_FORCE_PATH_STYLE=true
STORAGE_UPLOAD_PREFIX=uploads
SIGNED_UPLOAD_TTL_SECONDS=900
SIGNED_READ_TTL_SECONDS=900
ALLOWED_UPLOAD_MIME_TYPES=image/jpeg,image/png,image/webp,application/pdf,video/mp4,video/quicktime,video/x-m4v
MAX_UPLOAD_BYTES=209715200

# Database operations
DB_POOL_MAX=20
DB_POOL_IDLE_MS=30000
DB_POOL_CONNECT_TIMEOUT_MS=10000
DB_BACKUP_DIR=backups
# Emergency-only bypass. Never enable in normal production operation.
ALLOW_PENDING_MIGRATIONS=0

# Security hardening
UPLOAD_URL_RATE_LIMIT_MAX=120
PUBLIC_OBJECT_SEARCH_PATHS=public

# Durable PostgreSQL background queue
QUEUE_POLL_MS=1000
QUEUE_CONCURRENCY=4
QUEUE_RETRY_BASE_MS=500

# Protected operational metrics
METRICS_TOKEN=CHANGE_ME_LONG_RANDOM_64_CHARS_MIN

# Secure one-time first administrator bootstrap (do not retain password after use)
BOOTSTRAP_ADMIN_NAME=
BOOTSTRAP_ADMIN_PHONE=
BOOTSTRAP_ADMIN_EMAIL=
BOOTSTRAP_ADMIN_PASSWORD=
BOOTSTRAP_ADMIN_CONFIRM=CREATE_FIRST_ADMIN

# Operations and incident readiness
BACKUP_RETENTION_DAYS=30
AUDIT_LOG_RETENTION_DAYS=365
FAILED_JOB_RETENTION_DAYS=30
INCIDENT_COMMANDER_CONTACT=
SUPPORT_ESCALATION_EMAIL=
STATUS_PAGE_URL=
EAS_PROJECT_ID=42a7f8fe-68ea-4422-8f46-0def1f55abb9
