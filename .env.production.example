# Athoo production environment template.
# This file contains no real credentials. Copy it to .env.production and replace
# all REPLACE_WITH_* values in your deployment secret manager before launch.

NODE_ENV=production
DEPLOYMENT_ENVIRONMENT=production
RELEASE_SERVICE_NAME=athoo-api
RELEASE_VERSION=REPLACE_WITH_RELEASE_VERSION
# Optional explicit release identity. Render/GitHub values are used automatically when available.
RELEASE_COMMIT_SHA=
RELEASE_BUILD_ID=

# Public build provenance. These values are safe to expose and let connected
# verification prove that API, admin, and mobile artifacts came from one commit.
VITE_RELEASE_VERSION=REPLACE_WITH_RELEASE_VERSION
VITE_RELEASE_COMMIT_SHA=
VITE_RELEASE_BUILD_ID=
EXPO_PUBLIC_RELEASE_VERSION=REPLACE_WITH_RELEASE_VERSION
EXPO_PUBLIC_RELEASE_COMMIT_SHA=
EXPO_PUBLIC_RELEASE_BUILD_ID=

DATABASE_URL=postgresql://athoo_user:REPLACE_WITH_DATABASE_SECRET@database-host.invalid:5432/athoo?sslmode=require

JWT_SECRET=REPLACE_WITH_64_RANDOM_CHARACTERS_FOR_JWT_SIGNING_0000000000000000
REFRESH_TOKEN_SECRET=REPLACE_WITH_64_RANDOM_CHARACTERS_FOR_REFRESH_SIGNING_0000000000
SESSION_SECRET=REPLACE_WITH_64_RANDOM_CHARACTERS_FOR_SESSION_SIGNING_0000000000
OTP_HASH_SECRET=REPLACE_WITH_64_RANDOM_CHARACTERS_FOR_OTP_HASHING_00000000000000
JWT_ISSUER=athoo-api
JWT_AUDIENCE=athoo-mobile
TRUST_PROXY=1
SERVER_REQUEST_TIMEOUT_MS=120000
SERVER_HEADERS_TIMEOUT_MS=60000
SERVER_KEEP_ALIVE_TIMEOUT_MS=15000
WS_MAX_PAYLOAD_BYTES=65536
WS_MAX_CONNECTIONS_PER_SESSION=8
SHUTDOWN_TIMEOUT_MS=10000
LOG_LEVEL=info

# Request, database, and abuse-control limits. Keep these explicit so production
# behavior does not silently depend on source defaults.
BODY_LIMIT=2mb
MAX_JSON_DEPTH=12
MAX_STRING_FIELD_LENGTH=1200000
GLOBAL_RATE_LIMIT_WINDOW_MS=60000
GLOBAL_RATE_LIMIT_MAX=600
UPLOAD_URL_RATE_LIMIT_MAX=120
SLOW_REQUEST_MS=1000
DB_POOL_MAX=20
DB_POOL_IDLE_MS=30000
DB_POOL_CONNECT_TIMEOUT_MS=10000

API_BASE_URL=https://api.your-domain.invalid
ADMIN_BASE_URL=https://admin.your-domain.invalid
APP_BASE_URL=https://your-domain.invalid
CORS_ORIGIN=https://admin.your-domain.invalid
CORS_ORIGINS=https://admin.your-domain.invalid

# Storage is selected by configuration; route and mobile code never changes.
# Supported adapters: r2, s3, minio, wasabi, backblaze_b2,
# digitalocean_spaces, custom_s3, gcs, and local (development only).
STORAGE_PROVIDER=r2
STORAGE_UPLOAD_PREFIX=uploads
MAX_UPLOAD_BYTES=209715200
# Leave blank to use Athoo's built-in safe MIME allowlist.
ALLOWED_UPLOAD_MIME_TYPES=
SIGNED_UPLOAD_TTL_SECONDS=900
SIGNED_READ_TTL_SECONDS=900

# Canonical S3-compatible settings. These work for R2, AWS S3, MinIO,
# Wasabi, Backblaze B2 S3, DigitalOcean Spaces, and custom S3 endpoints.
STORAGE_S3_ENDPOINT=https://REPLACE_WITH_R2_ACCOUNT_ID.r2.cloudflarestorage.com
STORAGE_S3_REGION=auto
STORAGE_S3_ACCESS_KEY_ID=REPLACE_WITH_STORAGE_ACCESS_KEY
STORAGE_S3_SECRET_ACCESS_KEY=REPLACE_WITH_STORAGE_SECRET_KEY
STORAGE_S3_BUCKET=athoo
STORAGE_S3_FORCE_PATH_STYLE=true
# AWS S3 only: use the deployment IAM role/default credential chain instead of static keys.
STORAGE_S3_USE_DEFAULT_CREDENTIALS=false

# Backward-compatible Cloudflare R2/S3 names. They may remain empty when the
# canonical STORAGE_S3_* settings above are used.
CLOUDFLARE_R2_ACCOUNT_ID=
CLOUDFLARE_R2_ACCESS_KEY_ID=
CLOUDFLARE_R2_SECRET_ACCESS_KEY=
CLOUDFLARE_R2_BUCKET=
S3_ENDPOINT=
S3_REGION=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_BUCKET=
S3_FORCE_PATH_STYLE=

# Google Cloud Storage adapter (used only when STORAGE_PROVIDER=gcs).
# Use workload identity/application-default credentials where possible. A
# service-account JSON may be supplied through GCS_CREDENTIALS_JSON.
GCS_PROJECT_ID=
GCS_BUCKET=
GCS_CREDENTIALS_JSON=
GCS_KEY_FILE=
GCS_CLIENT_EMAIL=
GCS_PRIVATE_KEY=

# PostgreSQL durable queue. These values are bounded again in source.
QUEUE_PROVIDER=postgres
QUEUE_POLL_MS=1000
QUEUE_CONCURRENCY=4
QUEUE_STALE_LOCK_MINUTES=15
QUEUE_COMPLETED_RETENTION_DAYS=14
QUEUE_RETRY_BASE_MS=500
BROADCAST_DELIVERY_CONCURRENCY=10

# Memory cache is certified only for one API instance. `redis` is reserved and
# deliberately fails closed until the shared adapter migration is complete.
CACHE_PROVIDER=memory
MICRO_CACHE_TTL_MS=2500
MICRO_CACHE_MAX_ITEMS=500

PUSH_PROVIDER=expo
PUSH_PROVIDER_ENDPOINT=https://exp.host/--/api/v2/push/send
PUSH_RECEIPT_ENDPOINT=https://exp.host/--/api/v2/push/getReceipts
EXPO_ACCESS_TOKEN=
PUSH_TIMEOUT_MS=10000
PUSH_RECEIPT_TIMEOUT_MS=10000
PUSH_RECEIPT_DELAY_MS=20000
PUSH_RECEIPT_MAX_ATTEMPTS=5
EXPO_PUSH_BATCH_SIZE=100
PUSH_MAX_ATTEMPTS=3
PUSH_RETRY_BASE_MS=500
PUSH_BADGE_COUNT=1

# Optional provider-neutral JSON-over-HTTPS push adapter. Select it with
# PUSH_PROVIDER=http_json. Templates may use {token}, {title}, {body},
# {type}, {channelId}, {sound}, {ttl}, {badge}; use __ATHOO_PUSH_DATA__ for
# raw message data and __ATHOO_MESSAGES__ for the rendered batch array.
PUSH_HTTP_ENDPOINT=
PUSH_HTTP_METHOD=POST
PUSH_HTTP_AUTH_HEADER=Authorization
PUSH_HTTP_AUTH_PREFIX=Bearer 
PUSH_HTTP_AUTH_VALUE=
PUSH_HTTP_HEADERS_JSON=
PUSH_HTTP_TIMEOUT_MS=10000
PUSH_HTTP_BATCH_SIZE=100
PUSH_HTTP_BATCH_FIELD=messages
PUSH_HTTP_MESSAGE_TEMPLATE_JSON=
PUSH_HTTP_BODY_TEMPLATE_JSON=
PUSH_HTTP_ACCEPTED_PATH=
PUSH_HTTP_FAILED_PATH=
PUSH_HTTP_INVALID_TOKENS_PATH=
PUSH_HTTP_TICKET_IDS_PATH=

# Notification channels are build-time/mobile and server push configuration.
# Increment the version when changing Android channel sound/importance because
# Android treats an existing channel's audio settings as immutable.
NOTIFICATION_CHANNEL_VERSION=4
NOTIFICATION_CLEANUP_DEPRECATED_CHANNELS=true
NOTIFICATION_DEPRECATED_CHANNEL_IDS=jobs-v2,messages-v2,general-v2,calls-v2,jobs-v3,messages-v3,general-v3,calls-v3
NOTIFICATION_JOB_CHANNEL_ID=jobs-v4
NOTIFICATION_JOB_CHANNEL_NAME=Jobs and Booking Alerts
NOTIFICATION_JOB_SOUND=athoo_job.wav
NOTIFICATION_JOB_SOUND_ASSET=./assets/sounds/athoo_job.wav
NOTIFICATION_JOB_VIBRATION=0,500,180,500,180,500
NOTIFICATION_JOB_LIGHT_COLOR=#F97316
NOTIFICATION_JOB_TTL_SECONDS=900
NOTIFICATION_MESSAGE_CHANNEL_ID=messages-v4
NOTIFICATION_MESSAGE_CHANNEL_NAME=Chat Messages
NOTIFICATION_MESSAGE_SOUND=athoo_message.wav
NOTIFICATION_MESSAGE_SOUND_ASSET=./assets/sounds/athoo_message.wav
NOTIFICATION_MESSAGE_VIBRATION=0,220,120,220
NOTIFICATION_MESSAGE_LIGHT_COLOR=#8B5CF6
NOTIFICATION_MESSAGE_TTL_SECONDS=86400
NOTIFICATION_GENERAL_CHANNEL_ID=general-v4
NOTIFICATION_GENERAL_CHANNEL_NAME=General Updates
NOTIFICATION_GENERAL_SOUND=athoo_general.wav
NOTIFICATION_GENERAL_SOUND_ASSET=./assets/sounds/athoo_general.wav
NOTIFICATION_GENERAL_VIBRATION=0,300,120,300
NOTIFICATION_GENERAL_LIGHT_COLOR=#1A6EE0
NOTIFICATION_GENERAL_TTL_SECONDS=86400
NOTIFICATION_CALL_CHANNEL_ID=calls-v4
NOTIFICATION_CALL_CHANNEL_NAME=Incoming Calls
NOTIFICATION_CALL_SOUND=athoo_call.wav
NOTIFICATION_CALL_SOUND_ASSET=./assets/sounds/athoo_call.wav
NOTIFICATION_CALL_VIBRATION=0,700,250,700,250,700
NOTIFICATION_CALL_LIGHT_COLOR=#22C55E
NOTIFICATION_CALL_TTL_SECONDS=35

# Portable email adapter. Use EMAIL_PROVIDER=smtp for Zoho, SES SMTP,
# ZeptoMail SMTP, Postmark SMTP, or another standards-compatible provider.
EMAIL_PROVIDER=smtp
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_REQUIRE_TLS=true
SMTP_TLS_REJECT_UNAUTHORIZED=true
SMTP_USER=
SMTP_PASS=
SMTP_POOL=true
SMTP_MAX_CONNECTIONS=3
SMTP_MAX_MESSAGES_PER_CONNECTION=100
SMTP_CONNECTION_TIMEOUT_MS=10000
SMTP_GREETING_TIMEOUT_MS=10000
SMTP_SOCKET_TIMEOUT_MS=20000
EMAIL_FROM_NAME=Athoo
EMAIL_FROM_ADDRESS=
EMAIL_REPLY_TO=

# Optional provider-neutral JSON-over-HTTPS email adapter. Select it with
# EMAIL_PROVIDER=http_json. A custom body template may use {to}, {subject},
# {html}, {text}, {from}, {fromName}, {replyTo}, and __ATHOO_EMAIL_HEADERS__.
EMAIL_HTTP_ENDPOINT=
EMAIL_HTTP_METHOD=POST
EMAIL_HTTP_AUTH_HEADER=Authorization
EMAIL_HTTP_AUTH_PREFIX=Bearer 
EMAIL_HTTP_AUTH_VALUE=
EMAIL_HTTP_HEADERS_JSON=
EMAIL_HTTP_TIMEOUT_MS=10000
EMAIL_HTTP_HEALTHCHECK_URL=
EMAIL_HTTP_BODY_TEMPLATE_JSON=
EMAIL_HTTP_MESSAGE_ID_PATH=id
EMAIL_HTTP_TO_FIELD=to
EMAIL_HTTP_SUBJECT_FIELD=subject
EMAIL_HTTP_HTML_FIELD=html
EMAIL_HTTP_TEXT_FIELD=text
EMAIL_HTTP_FROM_FIELD=from
EMAIL_HTTP_FROM_NAME_FIELD=fromName
EMAIL_HTTP_REPLY_TO_FIELD=replyTo

EMAIL_BRAND_NAME=Athoo
EMAIL_BRAND_DESCRIPTOR=Trusted services, connected safely
EMAIL_BRAND_COLOR=#1A6EE0
EMAIL_SUPPORT_ADDRESS=
EMAIL_OTP_HASH_SECRET=
EMAIL_OTP_TTL_SECONDS=600
EMAIL_OTP_RESEND_COOLDOWN_SECONDS=45
EMAIL_OTP_MAX_ATTEMPTS=5
EMAIL_VERIFICATION_RATE_LIMIT_MAX=10
EMAIL_VERIFICATION_ATTEMPT_RATE_LIMIT_MAX=20
EMAIL_CHANGE_RATE_LIMIT_MAX=10
EMAIL_CHANGE_VERIFY_RATE_LIMIT_MAX=20
EMAIL_ADMIN_TEST_RATE_LIMIT_MAX=10
EMAIL_QUEUE_MAX_ATTEMPTS=4
EMAIL_CHALLENGE_RETENTION_DAYS=7
EMAIL_DELIVERY_RETENTION_DAYS=180
EMAIL_MAINTENANCE_INTERVAL_MS=21600000
EMAIL_NEW_DEVICE_ALERTS_ENABLED=true
EMAIL_MARKETING_ENABLED=false
EMAIL_MARKETING_MAX_RECIPIENTS=500
API_PUBLIC_URL=

OTP_TTL_SECONDS=600
OTP_RESEND_COOLDOWN_SECONDS=45
OTP_MAX_ATTEMPTS=5
ALLOW_DEV_OTP_RESPONSE=false

# Portable authentication OTP delivery. Delivery adapters are attempted in the
# configured order. Use all for redundant delivery or first_success to control cost.
OTP_DELIVERY_CHANNELS=whatsapp_cloud,email
OTP_DELIVERY_MODE=first_success
WHATSAPP_GRAPH_BASE_URL=https://graph.facebook.com
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_GRAPH_API_VERSION=v25.0
WHATSAPP_OTP_TEMPLATE_NAME=otp_verification
WHATSAPP_OTP_TEMPLATE_LANGUAGE=en
WHATSAPP_TIMEOUT_MS=10000

# Optional vendor-neutral JSON-over-HTTPS SMS adapter. Add http_sms to
# OTP_DELIVERY_CHANNELS only after these values are configured and tested.
SMS_PROVIDER=disabled
SMS_HTTP_ENDPOINT=
SMS_HTTP_METHOD=POST
SMS_HTTP_AUTH_HEADER=Authorization
SMS_HTTP_AUTH_VALUE=
SMS_HTTP_PHONE_FIELD=to
SMS_HTTP_MESSAGE_FIELD=message
SMS_HTTP_SENDER_FIELD=sender
SMS_HTTP_SENDER_VALUE=
SMS_OTP_MESSAGE_TEMPLATE=Your {brand} verification code is {code}. It expires in {minutes} minutes.
SMS_HTTP_TIMEOUT_MS=10000

SENTRY_DSN=
ERROR_TRACKING_DSN=
METRICS_TOKEN=REPLACE_WITH_OPERATIONAL_METRICS_TOKEN
ALLOW_PENDING_MIGRATIONS=0

# Voice/video provider abstraction. ICE credentials are returned only by the authenticated API.
CALL_PROVIDER=webrtc
MAX_CALL_AUDIO_CHUNK_B64=900000
ENABLE_LIVE_TRACKING=false
STUN_URLS=
TURN_URLS=
TURN_USERNAME=
TURN_CREDENTIAL=
CALL_FALLBACK_CHUNK_MS=800
CALL_PREFERRED_CODEC=opus

# Account activity and lifecycle scheduling. Policy thresholds remain admin-configurable.
USER_ACTIVITY_WRITE_INTERVAL_MS=600000
INACTIVITY_SWEEP_MIN_INTERVAL_MS=21600000
BOOKING_SWEEP_INTERVAL_MS=60000

# Production operations and escalation contacts.
INCIDENT_COMMANDER_CONTACT=
SUPPORT_ESCALATION_EMAIL=
STATUS_PAGE_URL=

# Provider-neutral map runtime. The mobile app always calls Athoo APIs, so
# changing these values never requires a mobile rebuild. Built-in providers:
# TomTom, Mapbox, Photon, Nominatim and OSRM. Any other HTTP provider can use
# the declarative MAP_CUSTOM_* adapter below.
MAP_PROVIDER=tomtom
MAP_TILE_PROVIDER=tomtom
MAP_SEARCH_PROVIDER=tomtom
MAP_REVERSE_PROVIDER=tomtom
MAP_DIRECTIONS_PROVIDER=tomtom
MAP_PROVIDER_FALLBACK_ENABLED=false
MAP_SEARCH_FALLBACK_PROVIDER=photon
MAP_REVERSE_FALLBACK_PROVIDER=photon
MAP_DIRECTIONS_FALLBACK_PROVIDER=osrm
MAP_COUNTRY_CODE=PK
MAP_LANGUAGE=en

# TomTom built-in adapter.
TOMTOM_API_KEY=
TOMTOM_BASE_URL=https://api.tomtom.com
TOMTOM_COUNTRY_SET=PK
TOMTOM_MAP_LANGUAGE=en-GB
TOMTOM_MAP_LAYER=basic
TOMTOM_MAP_STYLE=main
TOMTOM_MAP_VIEW=Unified
TOMTOM_TILE_SIZE=256
TOMTOM_ROUTE_TYPE=fastest
TOMTOM_TRAVEL_MODE=car
TOMTOM_TRAFFIC_ENABLED=true

# Optional Mapbox built-in adapter.
MAPBOX_ACCESS_TOKEN=
MAPBOX_STYLE_OWNER=mapbox
MAPBOX_STYLE_ID=streets-v12
MAPBOX_TILE_SIZE=512
MAPBOX_TILE_SCALE=
MAPBOX_COUNTRY_CODES=pk
MAPBOX_LANGUAGE=en
MAPBOX_GEOCODING_PERMANENT=false
MAPBOX_GEOCODING_BASE_URL=https://api.mapbox.com/search/geocode/v6
MAPBOX_DIRECTIONS_BASE_URL=https://api.mapbox.com/directions/v5
MAPBOX_DIRECTIONS_PROFILE=mapbox/driving

# Declarative custom HTTP adapter. Set MAP_PROVIDER to any provider label and
# supply these templates/paths to integrate it without changing source code.
MAP_CUSTOM_PROVIDER_ID=
MAP_CUSTOM_TILE_SIZE=256
MAP_CUSTOM_API_KEY=
MAP_CUSTOM_API_KEY_QUERY_PARAM=key
MAP_CUSTOM_API_KEY_HEADER=
MAP_CUSTOM_API_KEY_HEADER_PREFIX=
MAP_CUSTOM_HEADERS_JSON=
MAP_CUSTOM_GEOCODING_CACHEABLE=false
MAP_CUSTOM_TILE_URL_TEMPLATE=
MAP_CUSTOM_SEARCH_URL_TEMPLATE=
MAP_CUSTOM_SEARCH_RESULTS_PATH=results
MAP_CUSTOM_SEARCH_ID_PATH=id
MAP_CUSTOM_SEARCH_LABEL_PATH=label
MAP_CUSTOM_SEARCH_PRIMARY_PATH=name
MAP_CUSTOM_SEARCH_SECONDARY_PATH=address
MAP_CUSTOM_SEARCH_LAT_PATH=position.lat
MAP_CUSTOM_SEARCH_LNG_PATH=position.lon
MAP_CUSTOM_SEARCH_TYPE_PATH=type
MAP_CUSTOM_SEARCH_CITY_PATH=city
MAP_CUSTOM_SEARCH_PROVINCE_PATH=province
MAP_CUSTOM_SEARCH_POSTCODE_PATH=postcode
MAP_CUSTOM_SEARCH_DEFAULT_PRECISION=area
MAP_CUSTOM_REVERSE_URL_TEMPLATE=
MAP_CUSTOM_REVERSE_ADDRESS_PATH=address
MAP_CUSTOM_DIRECTIONS_URL_TEMPLATE=
MAP_CUSTOM_DIRECTIONS_POINTS_PATH=routes.0.points
MAP_CUSTOM_DIRECTIONS_POINT_LAT_PATH=latitude
MAP_CUSTOM_DIRECTIONS_POINT_LNG_PATH=longitude
MAP_CUSTOM_DIRECTIONS_DISTANCE_PATH=routes.0.distance
MAP_CUSTOM_DIRECTIONS_DISTANCE_UNIT=meters
MAP_CUSTOM_DIRECTIONS_DURATION_PATH=routes.0.duration
MAP_CUSTOM_DIRECTIONS_DURATION_UNIT=seconds

# Tile proxy, shared providers and safety limits.
MAP_TILE_UPSTREAM_URL=
MAP_TILE_API_KEY=
MAP_TILE_PROVIDER_NAME=
MAP_TILE_ATTRIBUTION=© TomTom | © OpenStreetMap contributors
MAP_TILE_USER_AGENT=AthooApp/1.0 (+https://athoo.pk)
MAP_TILE_ALLOW_OSM_DEVELOPMENT=false
MAP_TILE_TIMEOUT_MS=8000
MAP_TILE_BROWSER_CACHE_SECONDS=86400
MAP_TILE_CDN_CACHE_SECONDS=604800
MAP_TILE_MAX_BYTES=2097152
MAP_TILE_MAX_ZOOM=20
MAP_TILE_RESPECT_UPSTREAM_CACHE=true
MAP_CONTACT_EMAIL=support@athoo.pk
MAP_USER_AGENT=AthooApp/1.0 (+https://athoo.pk; contact: support@athoo.pk)
PHOTON_BASE_URL=https://photon.komoot.io
NOMINATIM_BASE_URL=https://nominatim.openstreetmap.org
NOMINATIM_SEARCH_FALLBACK=false
OSRM_BASE_URL=https://router.project-osrm.org
OSRM_PROFILE=driving
GEO_UPSTREAM_TIMEOUT_MS=6000
GEO_CACHE_MAX_ITEMS=500
GEO_RATE_LIMIT_WINDOW_MS=60000
GEO_SEARCH_RATE_LIMIT_MAX=60
GEO_REVERSE_RATE_LIMIT_MAX=60
GEO_DIRECTIONS_RATE_LIMIT_MAX=60


# Build-time brand configuration. Asset paths must point to files inside athoo-app.
APP_DISPLAY_NAME=Athoo
APP_SLUG=athoo-app
APP_SCHEME=athoo
BRAND_DESCRIPTOR=Home Services
BRAND_PRIMARY_COLOR="#1A6EE0"
BRAND_PRIMARY_PRESSED_COLOR="#1558B4"
BRAND_PRIMARY_DARK_COLOR="#60A5FA"
BRAND_PRIMARY_PRESSED_DARK_COLOR="#3B82F6"
BRAND_SECONDARY_COLOR="#F97316"
BRAND_SECONDARY_PRESSED_COLOR="#C4510B"
BRAND_SECONDARY_DARK_COLOR="#F97316"
BRAND_SECONDARY_PRESSED_DARK_COLOR="#EA580C"
APP_ICON_PATH=./assets/images/icon.png
ADAPTIVE_ICON_PATH=./assets/images/adaptive-icon.png
ADAPTIVE_ICON_BACKGROUND="#FFFFFF"
SPLASH_IMAGE_PATH=./assets/images/splash.png
SPLASH_BACKGROUND_LIGHT="#FFFFFF"
SPLASH_BACKGROUND_DARK="#08111F"
NOTIFICATION_ICON_PATH=./assets/images/notification-icon.png
EXPO_PUBLIC_BRAND_DISPLAY_NAME=Athoo
EXPO_PUBLIC_BRAND_DESCRIPTOR=Home Services
EXPO_PUBLIC_BRAND_PRIMARY_COLOR="#1A6EE0"
EXPO_PUBLIC_BRAND_PRIMARY_PRESSED_COLOR="#1558B4"
EXPO_PUBLIC_BRAND_PRIMARY_DARK_COLOR="#60A5FA"
EXPO_PUBLIC_BRAND_PRIMARY_PRESSED_DARK_COLOR="#3B82F6"
EXPO_PUBLIC_BRAND_SECONDARY_COLOR="#F97316"
EXPO_PUBLIC_BRAND_SECONDARY_PRESSED_COLOR="#C4510B"
EXPO_PUBLIC_BRAND_SECONDARY_DARK_COLOR="#F97316"
EXPO_PUBLIC_BRAND_SECONDARY_PRESSED_DARK_COLOR="#EA580C"

# Public mobile build configuration. These are non-secret values.
APP_ENV=production
EAS_PROJECT_ID=REPLACE_WITH_EAS_PROJECT_ID
EXPO_PUBLIC_API_BASE_URL=https://api.your-domain.invalid
EXPO_PUBLIC_MAP_TILE_URL=https://api.your-domain.invalid/api/geo/tiles/{z}/{x}/{y}.png
EXPO_PUBLIC_MAP_ATTRIBUTION=© TomTom | © OpenStreetMap contributors
EXPO_PUBLIC_MAP_TILE_SIZE=256
# Foreground provider GPS refresh cadence (bounded in-app to 60,000–600,000 ms)
EXPO_PUBLIC_PROVIDER_LOCATION_SYNC_INTERVAL_MS=120000
EXPO_PUBLIC_PUSH_TOKEN_SYNC_INTERVAL_MS=900000
EXPO_PUBLIC_SUPPORT_WHATSAPP_URL=
EXPO_PUBLIC_SUPPORT_INSTAGRAM_URL=
EXPO_PUBLIC_SUPPORT_FACEBOOK_URL=
EXPO_PUBLIC_SUPPORT_EMAIL=
EXPO_PUBLIC_SUPPORT_PHONE_DISPLAY=
EXPO_PUBLIC_SUPPORT_SOCIAL_HANDLE=
EXPO_PUBLIC_APP_DOWNLOAD_URL=
EXPO_PUBLIC_MAP_EXTERNAL_ANDROID_URL_TEMPLATE=geo:{lat},{lng}?q={lat},{lng}({label})
EXPO_PUBLIC_MAP_EXTERNAL_IOS_URL_TEMPLATE=https://maps.apple.com/?ll={lat},{lng}&q={label}
EXPO_PUBLIC_MAP_EXTERNAL_WEB_URL_TEMPLATE=
EXPO_PUBLIC_MAP_EXTERNAL_ANDROID_SEARCH_URL_TEMPLATE=geo:0,0?q={query}
EXPO_PUBLIC_MAP_EXTERNAL_IOS_SEARCH_URL_TEMPLATE=https://maps.apple.com/?q={query}
EXPO_PUBLIC_MAP_EXTERNAL_WEB_SEARCH_URL_TEMPLATE=
EXPO_PUBLIC_TERMS_URL=
EXPO_PUBLIC_PRIVACY_URL=

# Security: a successful login revokes every previous active session.

# Re-lock a remembered mobile session after this many background seconds.
EXPO_PUBLIC_BIOMETRIC_RELOCK_SECONDS=300
