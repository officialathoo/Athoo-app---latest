# Copy this file to a protected deployment environment and replace every placeholder.
NODE_ENV=production
PORT=5000
TRUST_PROXY=1

DATABASE_URL=postgresql://USER:PASSWORD@HOST/DATABASE?sslmode=require
JWT_SECRET=CHANGE_ME_WITH_AT_LEAST_32_RANDOM_CHARACTERS
REFRESH_TOKEN_SECRET=CHANGE_ME_WITH_A_DIFFERENT_32_CHAR_SECRET
SESSION_SECRET=CHANGE_ME_WITH_ANOTHER_32_CHAR_SECRET
OTP_HASH_SECRET=CHANGE_ME_WITH_A_SEPARATE_RANDOM_SECRET
JWT_ISSUER=athoo-api
JWT_AUDIENCE=athoo-mobile-admin

API_BASE_URL=https://api.example.com
ADMIN_BASE_URL=https://admin.example.com
APP_BASE_URL=https://example.com
CORS_ORIGIN=https://admin.example.com
CORS_ORIGINS=https://admin.example.com,https://example.com

STORAGE_PROVIDER=r2
CLOUDFLARE_R2_ACCOUNT_ID=CHANGE_ME
CLOUDFLARE_R2_ACCESS_KEY_ID=CHANGE_ME
CLOUDFLARE_R2_SECRET_ACCESS_KEY=CHANGE_ME
CLOUDFLARE_R2_BUCKET=athoo
S3_ENDPOINT=https://CHANGE_ME.r2.cloudflarestorage.com
S3_REGION=auto
S3_FORCE_PATH_STYLE=true

QUEUE_PROVIDER=postgres
CACHE_PROVIDER=memory
PUSH_PROVIDER=expo
EXPO_ACCESS_TOKEN=

SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM="Athoo <support@athoo.pk>"
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_GRAPH_API_VERSION=v25.0
SENTRY_DSN=
METRICS_TOKEN=CHANGE_ME_WITH_A_RANDOM_METRICS_TOKEN
ALLOW_PENDING_MIGRATIONS=0
ALLOW_DEV_OTP_RESPONSE=false
